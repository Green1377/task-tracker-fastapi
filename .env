# JWT настройки
JWT_SECRET_KEY=your-super-secret-key-change-this-in-production-please-1234567890
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
CORS_ORIGINS=[]
OPENLIBRARY_BASE_URL=https://openlibrary.org
OPENLIBRARY_TIMEOUT=10.0
ENVIRONMENT=development
DEBUG=true
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5433/library_catalog
API_V1_PREFIX=/api/v1
LOG_LEVEL=INFO